# Copie este arquivo para .env e preencha os valores
# No Railway: vá em Variables e adicione cada linha como uma variável

DATABASE_URL=postgresql+asyncpg://user:password@host:5432/manga
SECRET_KEY=gere-com-openssl-rand-hex-32

ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...
OPENAI_API_KEY=sk-...

TELEGRAM_TOKEN=123456:AAAA...   # obtido via @BotFather
TELEGRAM_ADMIN_ID=0             # seu ID numérico (use @userinfobot)

DEBUG=false
APP_NAME=Arpia
APP_VERSION=1.0.0

# CORS origins adicionais (separados por vírgula em Railway)
# ALLOWED_ORIGINS=["https://pap.sociedadetucci.com.br","http://localhost:5173"]

# MEKY (opcional — só se Arpia e Amanda rodarem no mesmo host)
MEKY_VISION_SOCKET=/tmp/meky-vision.sock
INAT_TOKEN=    # iNaturalist OAuth token (eco-logging de fauna)
